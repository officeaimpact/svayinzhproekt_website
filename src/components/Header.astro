---
import { site } from '../data/site';

const navItems = [
  { href: '/services/', label: 'Услуги' },
  { href: '/cases/', label: 'Проекты' },
  { href: '/equipment/', label: 'Техника' },
  { href: '/partners/', label: 'Партнёры' },
  { href: '/about/', label: 'О компании' },
  { href: '/contacts/', label: 'Контакты' },
];

const mobileExtraItems = [
  { href: '/journal/', label: 'Журнал' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container-page header-inner">
    <a href="/" class="logo" aria-label={`Главная страница ${site.brand}`}>
      <img
        src="/images/logo-mark.png"
        alt={site.brand}
        class="logo-mark-img"
        width="605"
        height="490"
        loading="eager"
        decoding="async"
      />
    </a>

    <div class="header-actions">
      <a
        href={`tel:${site.contacts.phoneRaw}`}
        class="header-phone"
        aria-label={`Позвонить ${site.contacts.phoneFormatted}`}
      >
        <svg class="phone-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="phone-text">{site.contacts.phoneFormatted}</span>
      </a>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Открыть меню"
        aria-expanded="false"
        aria-controls="primary-nav"
        data-nav-toggle
      >
        <span class="nav-toggle-line"></span>
        <span class="nav-toggle-line"></span>
        <span class="nav-toggle-line"></span>
      </button>
    </div>

    <nav id="primary-nav" class="primary-nav" aria-label="Основная навигация">
      <ul>
        {
          navItems.map((item) => {
            const isActive =
              item.href === '/'
                ? currentPath === '/'
                : currentPath.startsWith(item.href);
            return (
              <li>
                <a href={item.href} aria-current={isActive ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
        {
          mobileExtraItems.map((item) => {
            const isActive = currentPath.startsWith(item.href);
            return (
              <li class="nav-item-mobile-only">
                <a href={item.href} aria-current={isActive ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
        <li class="nav-cta-item">
          <a href="/contacts/#zayavka" class="nav-cta">
            Оставить заявку
          </a>
        </li>
      </ul>

      <div class="mobile-contacts">
        <a href={`tel:${site.contacts.phoneRaw}`} class="mobile-contact-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{site.contacts.phoneFormatted}</span>
        </a>
        <a href={`mailto:${site.contacts.email}`} class="mobile-contact-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{site.contacts.email}</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const nav = document.getElementById('primary-nav');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('is-open', !expanded);
    document.body.classList.toggle('nav-open', !expanded);
  });

  document.querySelectorAll<HTMLAnchorElement>('#primary-nav a').forEach((link) => {
    link.addEventListener('click', () => {
      nav?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('nav-open');
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    color: var(--color-paper);
    border-bottom: 1px solid var(--color-line-dark);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 76px;
    gap: 1rem;
    flex-wrap: nowrap;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .header-inner {
      min-height: 84px;
    }
  }

  @media (min-width: 1280px) {
    .header-inner {
      gap: 1.5rem;
      min-height: 88px;
    }
  }

  @media (min-width: 1440px) {
    .header-inner {
      gap: 2rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    color: var(--color-paper);
    flex-shrink: 0;
    /* Чуть-чуть «выпускаем» знак за верх/низ строки навигации,
       чтобы при компактном хедере он смотрелся крупно и уверенно. */
    margin-block: -4px;
  }

  .logo-mark-img {
    height: 56px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .logo-mark-img {
      height: 64px;
    }
  }

  @media (min-width: 1280px) {
    .logo-mark-img {
      height: 68px;
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-paper);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.01em;
    line-height: 1;
    transition: color 150ms ease-out;
    min-height: 44px;
    padding: 0.5rem 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (min-width: 1440px) {
    .header-phone {
      font-size: 0.9375rem;
    }
  }

  .header-phone:hover {
    color: var(--color-accent);
  }

  .header-phone .phone-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .header-phone .phone-text {
    display: none;
  }

  @media (min-width: 640px) {
    .header-phone .phone-text {
      display: inline;
    }
  }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    border: 1px solid var(--color-line-dark);
    background: transparent;
    cursor: pointer;
    padding: 10px;
  }

  .nav-toggle-line {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-paper);
  }

  .primary-nav {
    display: none;
  }

  .primary-nav ul {
    display: flex;
    align-items: center;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .primary-nav a {
    color: var(--color-paper);
    padding: 0.5rem 0.6rem;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: color 150ms ease-out;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    white-space: nowrap;
  }

  @media (min-width: 1440px) {
    .primary-nav a {
      padding: 0.5rem 0.875rem;
      font-size: 1rem;
    }
  }

  /* «Журнал» — пункт только для мобильного меню, чтобы desktop-навигация не переполнялась */
  .nav-item-mobile-only {
    display: none;
  }

  .primary-nav a:hover {
    color: var(--color-accent);
  }

  .primary-nav a[aria-current='page'] {
    color: var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
  }

  .nav-cta {
    background: var(--color-accent);
    color: var(--color-accent-on) !important;
    padding: 0.5625rem 0.875rem !important;
    border-radius: 2px;
    font-weight: 600;
    font-size: 0.875rem;
    transition: background 150ms ease-out;
    margin-left: 0.5rem;
    white-space: nowrap;
  }

  @media (min-width: 1440px) {
    .nav-cta {
      padding: 0.625rem 1rem !important;
      font-size: 0.9375rem;
    }
  }

  .nav-cta:hover {
    background: var(--color-accent-soft);
    border-bottom: none !important;
  }

  .nav-cta[aria-current='page'] {
    border-bottom: none !important;
    color: var(--color-accent-on) !important;
  }

  .mobile-contacts {
    display: none;
  }

  @media (min-width: 1280px) {
    .nav-toggle {
      display: none;
    }

    .primary-nav {
      display: block;
    }
  }

  @media (max-width: 1279px) {
    .nav-item-mobile-only {
      display: list-item;
    }

    .primary-nav {
      position: fixed;
      inset: 76px 0 0 0;
      background: var(--color-bg);
      padding: 2rem 1.5rem;
      transform: translateY(-100%);
      transition: transform 200ms ease-out;
      overflow-y: auto;
    }

    .primary-nav.is-open {
      display: block;
      transform: translateY(0);
    }

    .primary-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .primary-nav li {
      border-bottom: 1px solid var(--color-line-dark);
    }

    .primary-nav a {
      padding: 1.125rem 0;
      font-size: 1.0625rem;
      width: 100%;
    }

    .primary-nav a[aria-current='page'] {
      border-bottom: none;
      color: var(--color-accent);
    }

    .nav-cta-item {
      border-bottom: none !important;
      margin-top: 1rem;
    }

    .nav-cta {
      margin-left: 0;
      text-align: center;
      padding: 1rem !important;
      font-size: 1rem;
    }

    .mobile-contacts {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--color-line-dark);
    }

    .mobile-contact-row {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      color: var(--color-mute-light);
      font-size: 0.9375rem;
      min-height: 44px;
    }

    .mobile-contact-row svg {
      color: var(--color-accent);
      flex-shrink: 0;
    }

    .mobile-contact-row:hover {
      color: var(--color-paper);
    }
  }
</style>
