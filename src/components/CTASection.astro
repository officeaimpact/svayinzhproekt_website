---
import LeadForm from './LeadForm.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  text?: string;
  source?: string;
}

const {
  title = 'Обсудим ваш объект',
  text =
    'Передайте имя и контакт — свяжемся в течение рабочего дня. Если удобнее напрямую — позвоните или напишите в мессенджеры.',
  source = 'cta-section',
} = Astro.props;
---

<section class="cta section-dark">
  <div class="container-page">
    <div class="cta-grid">
      <div class="cta-form">
        <LeadForm variant="dark" title={title} subtitle={text} source={source} />
      </div>

      <aside class="cta-direct">
        <p class="eyebrow direct-eyebrow">Связаться напрямую</p>

        <ul class="direct-list" role="list">
          <li>
            <span class="direct-label">Телефон</span>
            <a class="direct-value" href={`tel:${site.contacts.phoneRaw}`}>
              {site.contacts.phoneFormatted}
            </a>
          </li>
          <li>
            <span class="direct-label">E-mail</span>
            <a class="direct-value" href={`mailto:${site.contacts.email}`}>
              {site.contacts.email}
            </a>
          </li>
        </ul>

        <div class="direct-messengers" aria-label="Мессенджеры">
          <a
            href={site.contacts.whatsapp}
            target="_blank"
            rel="noopener"
            class="msg-btn msg-wa"
            aria-label="Написать в WhatsApp"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
            </svg>
            <span>WhatsApp</span>
          </a>
          <a
            href={site.contacts.telegram}
            target="_blank"
            rel="noopener"
            class="msg-btn msg-tg"
            aria-label="Написать в Telegram"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
            <span>Telegram</span>
          </a>
        </div>

        <a href="/contacts/" class="direct-more">
          Все контакты
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </aside>
    </div>
  </div>
</section>

<style>
  .cta {
    padding-block: 4rem;
  }

  @media (min-width: 768px) {
    .cta {
      padding-block: 5.5rem;
    }
  }

  .cta-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .cta-grid {
      grid-template-columns: 1.4fr 1fr;
      gap: 4.5rem;
    }
  }

  /* Direct contacts column */
  .cta-direct {
    padding-top: 1rem;
  }

  @media (min-width: 1024px) {
    .cta-direct {
      padding-top: 4.75rem;
      padding-left: 2rem;
      border-left: 1px solid var(--color-line-dark);
    }
  }

  .direct-eyebrow {
    margin-bottom: 1rem;
    color: var(--color-accent-2);
  }

  .direct-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .direct-list li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .direct-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-mute-light);
    font-weight: 600;
  }

  .direct-value {
    color: var(--color-paper);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1875rem;
    letter-spacing: 0.005em;
    line-height: 1.2;
    transition: color 150ms ease-out;
    word-break: break-word;
  }

  .direct-value:hover {
    color: var(--color-accent);
  }

  .direct-messengers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .msg-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-line-dark);
    color: var(--color-paper);
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 2px;
    transition: background 150ms ease-out, border-color 150ms ease-out, color 150ms ease-out;
    min-height: 44px;
  }

  .msg-btn svg {
    flex-shrink: 0;
  }

  .msg-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-on);
  }

  .direct-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-mute-light);
    font-size: 0.9375rem;
    font-weight: 600;
    transition: color 150ms ease-out;
  }

  .direct-more:hover {
    color: var(--color-accent);
  }

  .direct-more .arrow {
    transition: transform 200ms ease-out;
  }

  .direct-more:hover .arrow {
    transform: translateX(4px);
  }
</style>
