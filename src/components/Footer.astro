---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-page">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label={`Главная страница ${site.brand}`}>
          <img
            src="/images/logo-mark.png"
            alt=""
            class="footer-logo-mark"
            width="605"
            height="490"
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          />
          <span class="footer-brand-name">
            <span>Свай</span><span class="accent">Инж</span><span>Проект</span>
          </span>
        </a>
        <p class="footer-tag">{site.tagline}</p>
        <p class="footer-desc">
          {site.description}
        </p>
      </div>

      <div class="footer-col">
        <h4>Услуги</h4>
        <ul>
          {site.services.map((s) => (
            <li><a href={`/services/${s.slug}/`}>{s.title}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Компания</h4>
        <ul>
          <li><a href="/about/">О компании</a></li>
          <li><a href="/equipment/">Техника и база</a></li>
          <li><a href="/geography/">География работ</a></li>
          <li><a href="/partners/">Партнёры</a></li>
          <li><a href="/cases/">Реализованные проекты</a></li>
          <li><a href="/journal/">Журнал</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Контакты</h4>
        <ul class="footer-contacts">
          <li>
            <span class="fc-label">Телефон</span>
            <a href={`tel:${site.contacts.phoneRaw}`} class="fc-value">
              {site.contacts.phoneFormatted}
            </a>
          </li>
          <li>
            <span class="fc-label">E-mail</span>
            <a href={`mailto:${site.contacts.email}`} class="fc-value">
              {site.contacts.email}
            </a>
          </li>
        </ul>
        <div class="footer-msg" aria-label="Мессенджеры">
          <a
            href={site.contacts.whatsapp}
            target="_blank"
            rel="noopener"
            class="footer-msg-btn"
            aria-label="Написать в WhatsApp"
            title="WhatsApp"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
            </svg>
          </a>
          <a
            href={site.contacts.telegram}
            target="_blank"
            rel="noopener"
            class="footer-msg-btn"
            aria-label="Написать в Telegram"
            title="Telegram"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
          </a>
        </div>
        <ul class="footer-meta-links">
          <li><a href="/contacts/">Все контакты</a></li>
          <li><a href="/docs/">Документы</a></li>
          <li><a href="/legal/">Правовая</a></li>
        </ul>
      </div>
    </div>

    <hr class="footer-divider" />

    <div class="footer-bottom">
      <div class="footer-legal">
        <div>{site.legalName}</div>
        <div>ИНН {site.legal.inn} · ОГРНИП {site.legal.ogrnip}</div>
        <div>{site.legal.address}</div>
      </div>
      <div class="footer-copy">
        © {year} {site.brand}. Все материалы защищены.
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    color: var(--color-paper);
    padding-block: 4rem 2rem;
    margin-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
    }
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .footer-logo-mark {
    height: 52px;
    width: auto;
    display: block;
    flex-shrink: 0;
  }

  .footer-brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-paper);
    letter-spacing: 0.01em;
  }

  .footer-brand-name .accent {
    color: var(--color-accent);
  }

  .footer-tag {
    font-size: 0.875rem;
    color: var(--color-paper);
    margin: 0 0 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .footer-desc {
    color: var(--color-mute-light);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-top: 1rem;
    max-width: 28rem;
  }

  .footer-col h4 {
    color: var(--color-paper);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 1.25rem;
    font-weight: 600;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col a {
    color: var(--color-mute-light);
    font-size: 0.9375rem;
    transition: color 150ms ease-out;
  }

  .footer-col a:hover {
    color: var(--color-accent);
  }

  /* Контактный блок в футере */
  .footer-contacts {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0 0 1.25rem !important;
  }

  .footer-contacts li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .fc-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-mute);
    font-weight: 600;
  }

  .fc-value {
    color: var(--color-paper) !important;
    font-weight: 600;
    font-size: 0.9375rem !important;
    word-break: break-word;
  }

  .fc-value:hover {
    color: var(--color-accent) !important;
  }

  .footer-msg {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .footer-msg-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px !important;
    height: 38px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-line-dark);
    color: var(--color-mute-light) !important;
    border-radius: 2px;
    transition: background 150ms ease-out, color 150ms ease-out, border-color 150ms ease-out;
  }

  .footer-msg-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-on) !important;
  }

  .footer-meta-links {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: wrap !important;
    gap: 1rem !important;
    padding-top: 1rem !important;
    border-top: 1px solid var(--color-line-dark);
  }

  .footer-meta-links a {
    font-size: 0.8125rem !important;
  }

  .footer-divider {
    border: 0;
    height: 1px;
    background: var(--color-line-dark);
    margin: 3rem 0 2rem;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    color: var(--color-mute-light);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
    }
  }

  .footer-legal > div {
    margin-bottom: 0.25rem;
  }

  .footer-copy {
    text-align: left;
  }

  @media (min-width: 768px) {
    .footer-copy {
      text-align: right;
    }
  }
</style>
