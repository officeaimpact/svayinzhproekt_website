---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Хлебные крошки">
  <div class="container-page">
    <ol>
      <li>
        <a href="/">Главная</a>
      </li>
      {
        items.map((item, idx) => (
          <li>
            <span class="sep" aria-hidden="true">/</span>
            {item.href && idx < items.length - 1 ? (
              <a href={item.href}>{item.label}</a>
            ) : (
              <span aria-current="page">{item.label}</span>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</nav>

<style>
  .breadcrumbs {
    background: var(--color-paper-2);
    border-bottom: 1px solid var(--color-line);
    padding-block: 1rem;
    font-size: 0.875rem;
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 0.5rem;
    color: var(--color-mute);
  }

  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumbs a {
    color: var(--color-mute);
    transition: color 150ms ease-out;
  }

  .breadcrumbs a:hover {
    color: var(--color-ink);
  }

  .breadcrumbs [aria-current='page'] {
    color: var(--color-ink);
    font-weight: 500;
  }

  .sep {
    color: var(--color-mute-light);
  }
</style>
