---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPage from '../components/HeroPage.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Section from '../components/Section.astro';
import LeadForm from '../components/LeadForm.astro';
import { site } from '../data/site';

const contactJsonLd = {
  '@type': 'ContactPage',
  mainEntity: { '@id': `${site.url}/#organization` },
};
---

<BaseLayout
  title="Контакты"
  description={`Связаться со специализированным буровым подрядчиком СвайИнжПроект. Телефон ${site.contacts.phoneFormatted}, e-mail ${site.contacts.email}. Производственная база — Москва, район Зорге (МЦК Зорге).`}
  jsonLd={contactJsonLd}
>
  <HeroPage
    eyebrow="Контакты"
    title="Связаться с инженерной командой"
    lead="Передайте параметры объекта, проектную документацию и геологию — свяжемся в течение рабочего дня и подготовим коммерческое предложение под параметры площадки."
    imageSrc="/images/hero/contacts.jpg"
  />

  <Breadcrumbs items={[{ label: 'Контакты' }]} />

  <Section>
    <div class="contacts-grid">
      <div class="contacts-list">
        <p class="eyebrow">Прямая связь</p>
        <h2 class="contacts-h">Канал связи · телефон, e-mail, мессенджеры</h2>

        <div class="contact-cards">
          <a href={`tel:${site.contacts.phoneRaw}`} class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="contact-body">
              <p class="contact-label">Телефон</p>
              <p class="contact-value">{site.contacts.phoneFormatted}</p>
              <p class="contact-sub">Звонок · оптимально в рабочее время</p>
            </div>
          </a>

          <a href={`mailto:${site.contacts.email}`} class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="contact-body">
              <p class="contact-label">E-mail</p>
              <p class="contact-value">{site.contacts.email}</p>
              <p class="contact-sub">Для коммерческих запросов и документации</p>
            </div>
          </a>

          <a href={site.contacts.whatsapp} target="_blank" rel="noopener" class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0 0 20.464 3.488"/>
              </svg>
            </div>
            <div class="contact-body">
              <p class="contact-label">WhatsApp</p>
              <p class="contact-value">{site.contacts.phoneFormatted}</p>
              <p class="contact-sub">Быстрый канал — пересылка документов и переговоры</p>
            </div>
          </a>

          <a href={site.contacts.telegram} target="_blank" rel="noopener" class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </div>
            <div class="contact-body">
              <p class="contact-label">Telegram</p>
              <p class="contact-value">{site.contacts.phoneFormatted}</p>
              <p class="contact-sub">Передача чертежей, ведомостей свай, фото площадки</p>
            </div>
          </a>
        </div>
      </div>

      <aside class="contacts-side">
        <h3>Юридическое лицо</h3>
        <dl>
          <dt>Наименование</dt>
          <dd>{site.legalName}</dd>
          <dt>ИНН</dt>
          <dd>{site.legal.inn}</dd>
          <dt>ОГРНИП</dt>
          <dd>{site.legal.ogrnip}</dd>
          <dt>Юридический адрес</dt>
          <dd>{site.legal.address}</dd>
        </dl>
        <h3 style="margin-top: 2rem;">База</h3>
        <dl>
          <dt>Регион</dt>
          <dd>Москва</dd>
          <dt>Ориентир</dt>
          <dd>Хорошёвский район, рядом со станцией МЦК Зорге</dd>
          <dt>Назначение</dt>
          <dd>Механический цех, склад обсадных и бетонолитных труб, воронок, сварочного оборудования</dd>
        </dl>
        <p class="map-note">
          Открыть район на <a href="https://yandex.ru/maps/?text=МЦК+Зорге" target="_blank" rel="noopener">Яндекс.Картах</a>.
        </p>
      </aside>
    </div>
  </Section>

  <Section dark id="zayavka">
    <div class="zayavka-grid">
      <LeadForm
        variant="dark"
        title="Оставить заявку"
        subtitle="Передайте имя и контакт — свяжемся в течение рабочего дня. Изучим документы, обсудим параметры и подготовим коммерческое предложение."
        source="contacts-page"
      />

      <div class="zayavka-info">
        <p class="eyebrow direct-eyebrow">Что приложить к обращению</p>
        <ul class="checklist">
          <li>Адрес объекта, фотографии и схема площадки.</li>
          <li>Геологические изыскания (если есть).</li>
          <li>Проектная или рабочая документация.</li>
          <li>Ведомость свай — количество, диаметры, глубины.</li>
          <li>Желаемые сроки начала работ.</li>
          <li>Тип сотрудничества — прямой договор или субподряд.</li>
          <li>Имя и контактные данные ответственного со стороны заказчика.</li>
          <li>Особые требования — режим работы, шумовые ограничения, доступ техники.</li>
          <li>Для 44-ФЗ / 223-ФЗ — данные тендера и генподрядчика.</li>
        </ul>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .contacts-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .contacts-grid {
      grid-template-columns: 1.4fr 1fr;
      gap: 4rem;
    }
  }

  .contacts-h {
    margin: 0.5rem 0 1.75rem;
    font-size: 1.5rem;
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .contacts-h {
      font-size: 1.875rem;
    }
  }

  .contact-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .contact-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: white;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-accent);
    color: var(--color-ink);
    transition: transform 150ms ease-out, box-shadow 150ms ease-out, border-color 150ms ease-out;
  }

  .contact-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -16px rgba(11, 27, 44, 0.18);
    border-left-color: var(--color-accent-soft);
  }

  .contact-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-paper-2);
    color: var(--color-accent);
    border-radius: 2px;
  }

  .contact-body {
    flex: 1;
    min-width: 0;
  }

  .contact-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-mute);
    margin: 0 0 0.25rem;
    font-weight: 600;
  }

  .contact-value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    margin: 0 0 0.35rem;
    color: var(--color-ink);
    word-break: break-word;
  }

  .contact-sub {
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-mute);
    margin: 0;
  }

  /* Side */
  .contacts-side {
    background: var(--color-paper-2);
    padding: 2rem;
  }

  .contacts-side h3 {
    color: var(--color-mute);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 1rem;
    margin: 0 0 1.5rem;
  }

  .contacts-side dl {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem 0;
    margin: 0;
  }

  .contacts-side dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-mute);
    margin-bottom: 0.25rem;
    font-weight: 600;
  }

  .contacts-side dd {
    font-size: 0.9375rem;
    color: var(--color-ink);
    margin: 0 0 1rem;
    line-height: 1.5;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-line);
  }

  .contacts-side dd:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .map-note {
    margin: 1rem 0 0;
    color: var(--color-mute);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .map-note a {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
  }

  /* Zayavka section */
  .zayavka-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .zayavka-grid {
      grid-template-columns: 1.4fr 1fr;
      gap: 4rem;
    }
  }

  .direct-eyebrow {
    color: var(--color-accent-2) !important;
  }

  .checklist {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
  }

  .checklist li {
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-line-dark);
    color: var(--color-mute-light);
    font-size: 0.9375rem;
    line-height: 1.5;
    padding-left: 1.5rem;
    position: relative;
  }

  .checklist li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0.75rem;
    color: var(--color-accent);
    font-weight: 700;
  }
</style>
