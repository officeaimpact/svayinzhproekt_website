---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroPage from '../../components/HeroPage.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Section from '../../components/Section.astro';
import CTASection from '../../components/CTASection.astro';
import { site } from '../../data/site';

const serviceJsonLd = [
  {
    '@type': 'Service',
    name: 'Струйная цементация и земляные анкера',
    serviceType: 'Грунтоцементные сваи и анкерные конструкции',
    provider: { '@id': `${site.url}/#organization` },
    areaServed: { '@type': 'Country', name: 'Россия' },
  },
];
---

<BaseLayout
  title="Струйная цементация и грунтовые анкера"
  description="Грунтоцементные сваи по технологии jet-grouting и устройство земляных анкеров для портальных сооружений, оползневых склонов, ограждений котлованов. Опыт работы в гравийных отложениях, илах, глинах."
  jsonLd={serviceJsonLd}
>
  <HeroPage
    eyebrow="Услуги · 03"
    title="Струйная цементация и анкера"
    lead="Технологии укрепления грунтов и удержания подпорных конструкций. От усиления фундаментов существующих зданий до закрепления тоннельных порталов на оползневых склонах."
    imageSrc="/images/services/jet.jpg"
  />

  <Breadcrumbs items={[{ label: 'Услуги', href: '/services/' }, { label: 'Струйная цементация и анкера' }]} />

  <Section>
    <div class="prose-content">
      <h2>Грунтоцементные сваи (jet-grouting)</h2>
      <p>
        При воздействии на грунт сильной струи цемента под высоким давлением происходит перемешивание раствора и грунта — образуется грунтоцементная свая. После затвердения смеси формируется высокопрочный грунтобетон. Сваи могут быть неармированными или с центральной арматурой.
      </p>
      <p>
        Метод позволяет укреплять практически все виды грунтов — от гравийных отложений до мелкодисперсных илов и глин. Применяется для усиления фундаментов существующих зданий, создания противофильтрационных завес, укрепления оползневых склонов, ограждения котлованов в сложных гидрогеологических условиях.
      </p>

      <h2>Земляные анкера</h2>
      <p>
        Сегодня широко распространено применение внутренних анкерных креплений. Грунтовые анкера устанавливаются для восполнения нагрузки, оказываемой грунтом на ограждающую конструкцию. Создание скважин в грунте выполняется с помощью бурового, вибрационного, забивного и задавливающего оборудования. Глубина заделки анкера должна позволять выходить за пределы призмы обрушения грунта.
      </p>
      <p>
        Применяются:
      </p>
      <ul>
        <li>На портальных сооружениях тоннелей в оползневых склонах</li>
        <li>В ограждающих конструкциях котлованов метро и подземных паркингов</li>
        <li>Для закрепления подпорных стен на сложном рельефе</li>
        <li>При устройстве временных и постоянных анкеровок гидротехнических сооружений</li>
      </ul>

      <h2>Пример: титановые анкера длиной до 25 м</h2>
      <p>
        На объекте «Обход г. Сочи, тоннели №5 и №5а под «Мемориальным комплексом»» (2003–2009) команда выполнила портальные сооружения на оползневых склонах с применением титановых анкеров диаметром 50 мм длиной до 25 м. Это позволило обеспечить устойчивость двухъярусных портальных стен высотой до 12 м в сложных инженерно-геологических условиях.
      </p>
    </div>
  </Section>

  <CTASection />
</BaseLayout>
