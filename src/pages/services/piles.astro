---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroPage from '../../components/HeroPage.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Section from '../../components/Section.astro';
import CTASection from '../../components/CTASection.astro';
import { site } from '../../data/site';

const serviceJsonLd = [
  {
    '@type': 'Service',
    name: 'Буровые сваи',
    serviceType: 'Устройство буровых и свайных конструкций',
    provider: { '@id': `${site.url}/#organization` },
    areaServed: { '@type': 'Country', name: 'Россия' },
    description:
      'Все основные типы свайных конструкций: с обсадной трубой, CFA, буросекущие, буроинъекционные, винтовые, забивные железобетонные, вдавливаемые.',
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Виды буровых свай',
      itemListElement: [
        'Буронабивные сваи с обсадной трубой',
        'Буронабивные сваи CFA',
        'Буросекущие сваи',
        'Буроинъекционные сваи',
        'Винтовые буронабивные сваи',
        'Железобетонные забивные сваи',
        'Вдавливаемые сваи',
      ].map((s) => ({
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: s },
      })),
    },
  },
];
---

<BaseLayout
  title="Буровые сваи: виды, технологии, диаметры"
  description="Устройство буронабивных свай с обсадной трубой и CFA, буросекущих, буроинъекционных, винтовых, забивных и вдавливаемых свай. Свои комплекты обсадных и бетонолитных труб, центраторы, сварочное оборудование."
  jsonLd={serviceJsonLd}
>
  <HeroPage
    eyebrow="Услуги · 01"
    title="Буровые сваи"
    lead="Все основные типы свайных конструкций для инфраструктурного и промышленного строительства. Работаем по СП 24.13330 «Свайные фундаменты», СП 50-102-2003 «Проектирование и устройство свайных фундаментов», ГОСТ 19804-2012 «Сваи железобетонные»."
    imageSrc="/images/services/piles.jpg"
  />

  <Breadcrumbs items={[{ label: 'Услуги', href: '/services/' }, { label: 'Буровые сваи' }]} />

  <Section>
    <div class="content-grid">
      <aside class="toc">
        <p class="eyebrow">Технологии</p>
        <ul>
          <li><a href="#obsadnaya">С обсадной трубой</a></li>
          <li><a href="#cfa">CFA</a></li>
          <li><a href="#burosekushhie">Буросекущие сваи</a></li>
          <li><a href="#injection">Буроинъекционные</a></li>
          <li><a href="#vintovye">Винтовые буронабивные</a></li>
          <li><a href="#zhb">Железобетонные забивные</a></li>
          <li><a href="#vdavl">Вдавливаемые</a></li>
        </ul>
      </aside>

      <div class="prose-content">
        <h2 id="obsadnaya">Буронабивные сваи с обсадной трубой</h2>
        <p>
          Скважина бурится с одновременным или последовательным погружением инвентарной обсадной трубы. Труба удерживает стенки скважины от обрушения в обводнённых, слабых и неустойчивых грунтах. После достижения проектной отметки в скважину опускается арматурный каркас, далее производится бетонирование через бетонолитную трубу с одновременным извлечением обсадной.
        </p>
        <p>
          У нас есть собственные комплекты обсадных труб разных диаметров и бетонолитных труб с воронками. Технология применяется в плотной городской застройке, рядом с существующими зданиями, на участках с высоким уровнем грунтовых вод.
        </p>
        <p>
          <strong>Пример:</strong> на объекте Дублёр Курортного проспекта в Сочи (2009–2013) команда выполнила двухъярусные свайные ограждающие конструкции высотой более 12 м на Северном и Южном порталах тоннелей №3 и №3а.
        </p>

        <h2 id="cfa">Буронабивные сваи по технологии CFA</h2>
        <p>
          CFA (Continuous Flight Auger) — непрерывное бурение полым шнековым буром. Бетон подаётся через полую штангу непосредственно при подъёме шнека, что исключает риск обрушения стенок и не требует обсадных труб.
        </p>
        <p>
          Метод эффективен в сухих, заболоченных, плотных, рыхлых грунтах, песчанике, туфе, известняке. Современное оборудование оснащено системой звукоизоляции, поэтому работы можно вести в густонаселённой городской среде. Это критически важно при возведении подземных паркингов жилых комплексов и деловых центров.
        </p>

        <h2 id="burosekushhie">Буросекущие сваи</h2>
        <p>
          Ограждающая конструкция котлована из чередующихся буронабивных свай — армированных и неармированных. Защищает стенки котлована от осыпания и проникновения грунтовых вод во время работ на обводнённых грунтах. Диаметр свай — от 380 до 1500 мм.
        </p>
        <p>
          Применяется для укрепления аварийных построек и в качестве комбинированных ограждающих и несущих конструкций.
        </p>

        <h2 id="injection">Буроинъекционные сваи</h2>
        <p>
          Сваи изготавливаются нагнетанием (инъекцией) раствора из песка и цемента или мелкозернистой бетонной смеси в готовую скважину. Метод применяется вблизи существующих зданий и сооружений при любом типе грунта, когда невозможна забивка или вибропогружение.
        </p>

        <h2 id="vintovye">Винтовые буронабивные сваи</h2>
        <p>
          Сваи с винтовой формой ствола, увеличивающей боковое сопротивление грунта. Эффективны в условиях, требующих повышенной несущей способности при ограниченной глубине заложения.
        </p>

        <h2 id="zhb">Железобетонные забивные сваи</h2>
        <p>
          Три типа призматических свай: сплошные с поперечным армированием ствола и предварительно напряжённой проволочной арматурой; сплошные без поперечного армирования; полые с круглой полостью.
        </p>

        <h2 id="vdavl">Вдавливаемые сваи</h2>
        <p>
          Сваи погружаются в грунт статическим вдавливанием без динамики. Метод применяется в исторической застройке, при санации существующих построек, в условиях, где нельзя нарушать целостность соседних зданий.
        </p>
      </div>
    </div>
  </Section>

  <Section dark tight>
    <p class="eyebrow">Кейсы по направлению</p>
    <h2>Где мы уже это делали</h2>
    <ul class="cases-mini">
      {site.cases.filter((c) => c.featured && c.slug !== 'rosseti-lep-110').map((c) => (
        <li>
          <a href={`/cases/${c.slug}/`}>
            <strong>{c.shortTitle ?? c.title}</strong>
            <span>{c.location}{c.period ? ` · ${c.period}` : ''}</span>
          </a>
        </li>
      ))}
    </ul>
  </Section>

  <CTASection />
</BaseLayout>

<style>
  .content-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .content-grid {
      grid-template-columns: 240px 1fr;
      gap: 4rem;
    }
  }

  .toc {
    position: sticky;
    top: 100px;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-left: 1px solid var(--color-line);
  }

  .toc a {
    display: block;
    padding: 0.375rem 1rem;
    color: var(--color-mute);
    font-size: 0.9375rem;
    line-height: 1.4;
    border-left: 2px solid transparent;
    margin-left: -1px;
    transition: color 150ms, border-color 150ms;
  }

  .toc a:hover {
    color: var(--color-ink);
    border-left-color: var(--color-accent);
  }

  .cases-mini {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-line-dark);
  }

  .cases-mini a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-line-dark);
    color: var(--color-paper);
    transition: color 150ms;
  }

  .cases-mini a:hover {
    color: var(--color-accent);
  }

  .cases-mini strong {
    font-size: 1.0625rem;
    font-weight: 600;
  }

  .cases-mini span {
    color: var(--color-mute-light);
    font-size: 0.875rem;
  }
</style>
