---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroPage from '../../components/HeroPage.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Section from '../../components/Section.astro';
import CTASection from '../../components/CTASection.astro';
import { articles } from '../../data/journal';
import { site } from '../../data/site';

const sorted = [...articles].sort((a, b) =>
  b.publishedAt.localeCompare(a.publishedAt),
);

const categories = Array.from(new Set(articles.map((a) => a.category)));

const jsonLd = {
  '@type': 'Blog',
  name: 'Журнал СвайИнжПроект',
  description: 'Технологии буровых и свайных работ, нормативы, кейсы.',
  blogPost: sorted.slice(0, 10).map((a) => ({
    '@type': 'BlogPosting',
    headline: a.title,
    url: new URL(`/journal/${a.slug}/`, site.url).toString(),
    datePublished: a.publishedAt,
    dateModified: a.updatedAt ?? a.publishedAt,
    image: new URL(a.heroImage, site.url).toString(),
    keywords: a.category,
  })),
};
---

<BaseLayout
  title="Журнал — технологии буровых и свайных работ"
  description="Технологии буровых и свайных работ, расчёты по СП 24.13330 и СП 50-102-2003, jet-grouting, шпунт, анкера, контроль качества свай. Регулярные публикации инженерной команды."
  jsonLd={jsonLd}
>
  <HeroPage
    eyebrow="Журнал"
    title="Технологии буровых и свайных работ"
    lead="Записи инженерной команды о технологиях, расчётах и контроле качества свай. Без воды и без маркетинга — только техническая суть."
    imageSrc="/images/hero/journal.jpg"
  />

  <Breadcrumbs items={[{ label: 'Журнал' }]} />

  <Section>
    <div class="journal-meta">
      <span>{articles.length} статей</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>обновление каждые 2–4 недели</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>{categories.length} разделов: {categories.join(', ')}</span>
    </div>

    <div class="articles-grid">
      {sorted.map((a) => (
        <article class="article-card">
          <a href={`/journal/${a.slug}/`} class="article-card-link">
            <div class="article-card-media">
              <img src={a.heroImage} alt={a.title} loading="lazy" decoding="async" class="photo-bw" />
            </div>
            <div class="article-card-body">
              <div class="article-card-meta">
                <span class="article-card-category">{a.category}</span>
                <span class="article-card-date">
                  {new Date(a.publishedAt).toLocaleDateString('ru-RU', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </span>
              </div>
              <h2 class="article-card-title">{a.title}</h2>
              <p class="article-card-subtitle">{a.subtitle}</p>
              <p class="article-card-reading">Чтение около {a.readingMinutes} мин</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </Section>

  <CTASection />
</BaseLayout>

<style>
  .journal-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--color-mute);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-line);
  }

  .dot {
    color: var(--color-mute-light);
  }

  .articles-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .articles-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .articles-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .article-card {
    display: flex;
  }

  .article-card-link {
    display: flex;
    flex-direction: column;
    background: var(--color-paper-2);
    color: var(--color-ink);
    border-top: 3px solid transparent;
    transition: background 200ms, border-color 200ms;
    flex: 1;
  }

  .article-card-link:hover {
    background: #fff;
    border-top-color: var(--color-accent);
  }

  .article-card-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .article-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .article-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-mute);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .article-card-category {
    color: var(--color-accent);
    font-weight: 600;
  }

  .article-card-title {
    font-size: 1.125rem;
    line-height: 1.3;
    margin: 0;
  }

  .article-card-subtitle {
    color: var(--color-ink-2);
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .article-card-reading {
    margin: 0.5rem 0 0;
    color: var(--color-mute);
    font-size: 0.8125rem;
  }
</style>
