---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPage from '../components/HeroPage.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Section from '../components/Section.astro';
import CTASection from '../components/CTASection.astro';
import { site } from '../data/site';

const timeline = [
  {
    period: '1998–2004',
    title: 'Кепшинский тоннель, Адлер — Красная Поляна',
    desc: 'Длина 3,4 км. Один из ранних объектов опыта инженерной команды.',
  },
  {
    period: '2003–2009',
    title: 'Обход г. Сочи: 5 тоннелей и 6 мостов',
    desc: 'Включая тоннели №5 и №5а под «Мемориальным комплексом» с двухъярусными свайными ограждающими конструкциями высотой более 12 м.',
  },
  {
    period: '2009–2013',
    title: 'Дублёр Курортного проспекта',
    desc: 'Четыре парных автомобильных тоннеля и четыре эстакады. Тоннели №3 и №3а с буровыми ограждающими конструкциями.',
  },
  {
    period: '2011–2015',
    title: 'Реконструкция пяти аэропортов',
    desc: 'Свайные основания зданий и сооружений: Екатеринбург, Магас, Владикавказ, Мурманск, Воронеж.',
  },
  {
    period: '2014–2015',
    title: 'М-29 «Кавказ», Республика Ингушетия',
    desc: 'Реконструкция автомобильной дороги федерального значения.',
  },
  {
    period: '2021–2023',
    title: 'М-12 «Москва — Казань», Дюртюли — Ачит',
    desc: 'Скоростная автомобильная дорога. Этап 1.3.1, км 0 — км 90. Десять искусственных сооружений силами команды.',
  },
  {
    period: 'Сейчас',
    title: 'Реконструкция ЛЭП 110 кВ в Москве',
    desc: 'Устройство буронабивных свай под опоры реконструируемой воздушной линии электропередачи в северо-западной части Москвы. Работаем в режиме субподряда.',
  },
];

const jsonLd = {
  '@type': 'AboutPage',
  name: 'О компании СвайИнжПроект',
  mainEntity: { '@id': `${site.url}/#organization` },
};
---

<BaseLayout
  title="О компании СвайИнжПроект"
  description="Специализированный подрядчик по буровым и свайным работам внутри партнёрской группы компаний полного цикла. Опыт инженерной команды — с 1998 года. Свой парк техники Casagrande и Bauer, производственная база в Москве."
  jsonLd={jsonLd}
>
  <HeroPage
    eyebrow="О компании"
    title="Специализированный подрядчик по буровым и свайным работам"
    lead="Команда выполняет буровые и свайные работы на инфраструктурных объектах с 1998 года: тоннели Сочи, мосты М-12, развязки Москвы, объекты энергетики, метро и аэропортов. Собственный парк Casagrande и Bauer, производственная база в Москве."
    imageSrc="/images/hero/about.jpg"
  />

  <Breadcrumbs items={[{ label: 'О компании' }]} />

  <Section>
    <div class="prose-content">
      <h2>Кто мы</h2>
      <p>
        СвайИнжПроект — специализированный подрядчик по буровым и свайным работам. За брендом — команда инженеров, машинистов и помощников бурильщиков с опытом на инфраструктурных объектах с 1998 года: Кепшинский тоннель, обход Сочи, Дублёр Курортного проспекта, М-29 «Кавказ», М-12 «Москва — Казань», развязки Москвы, объекты Россети и Автодор.
      </p>

      <h2>Что мы делаем</h2>
      <p>
        Главная специализация — буровые и свайные работы: буронабивные сваи с обсадной трубой и CFA, буросекущие и буроинъекционные сваи, винтовые, забивные железобетонные, вдавливаемые. Дополнительно — шпунтовое ограждение, jet-grouting, земляные анкера. Эти процессы закрываем своим парком Casagrande и Bauer, собственными комплектами обсадных и бетонолитных труб.
      </p>
      <p>
        Когда заказчику нужен полный цикл — фундаментные работы, монолит, металлоконструкции, инженерные сети, проектирование — мы выходим вместе с проверенными партнёрами. Каждая компания партнёрской группы закрывает свою специализацию.
      </p>

      <h2>Принципы работы</h2>
      <ul>
        <li>Соблюдение сроков. Установка должна работать минимум 9 месяцев в году — это базовая дисциплина.</li>
        <li>Открытая коммуникация с заказчиком и генподрядчиком. Без неожиданностей и без скрытых статей в смете.</li>
        <li>Документальная дисциплина — КС-2 и КС-3 по форме, счета-фактуры в срок, ЭДО где возможно.</li>
        <li>Работа с проектной и геологической документацией заказчика, без самостоятельных допущений по основанию.</li>
        <li>Прямая ответственность владельца за каждый объект. На крупных объектах — выезд лично.</li>
        <li>Гарантия качества по СНиП, СП и условиям договора.</li>
      </ul>

      <h2>Формат работы</h2>
      <p>
        Работаем по договорам субподряда у действующих генеральных подрядчиков. Также выходим на прямые подряды по 223-ФЗ и 44-ФЗ — это две основных рамки государственных и корпоративных закупок в Российской Федерации, под которые подаются крупные инфраструктурные тендеры.
      </p>
      <p>
        От запроса до сдачи объекта: изучение документации → выезд на площадку при необходимости → коммерческое предложение → договор → мобилизация → производство работ → исполнительная документация (КС-2 / КС-3) → гарантийный период.
      </p>

      <h2>Команда</h2>
      <p>
        В собственной бригаде — два машиниста буровой установки и пять помощников бурильщиков. На каждом объекте — прораб с инженерным образованием и опытом работы на сложных объектах. Под крупные объёмы привлекается техника и персонал партнёрских компаний без снижения качества и контроля.
      </p>

      <h2>Юридическое лицо</h2>
      <p>
        <span class="partner-name">{site.legalName}</span><br />
        ОГРНИП {site.legal.ogrnip}<br />
        ИНН {site.legal.inn}<br />
        {site.legal.address}
      </p>
      <p>
        Расчётный счёт в АО «ТБанк». Полные банковские реквизиты — на странице <a href="/legal/">«Правовая информация»</a>.
      </p>
    </div>
  </Section>

  <Section dark>
    <p class="eyebrow">Хронология</p>
    <h2>Объекты команды по годам</h2>
    <ol class="timeline">
      {timeline.map((t) => (
        <li>
          <span class="t-period">{t.period}</span>
          <div class="t-content">
            <h3>{t.title}</h3>
            <p>{t.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </Section>

  <CTASection />
</BaseLayout>

<style>
  .prose-content {
    max-width: 70ch;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
  }

  .timeline li {
    display: grid;
    gap: 1rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-line-dark);
  }

  @media (min-width: 768px) {
    .timeline li {
      grid-template-columns: 180px 1fr;
      gap: 2rem;
    }
  }

  .t-period {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.9375rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .t-content h3 {
    color: var(--color-paper);
    font-size: 1.0625rem;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .t-content p {
    color: var(--color-mute-light);
    font-size: 0.9375rem;
    line-height: 1.55;
    margin: 0;
  }
</style>
